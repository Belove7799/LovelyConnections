# ---- Server ----
PORT=3000
FRONTEND_URL=https://yourdomain.com

# ---- Database (Railway injects DATABASE_URL automatically once Postgres is attached) ----
DATABASE_URL=postgresql://user:password@host:port/dbname

# ---- Payments (manual — Zelle / Cash App) ----
# What the program costs, in cents (29900 = $299.00). Shown to the client
# and included in the admin notification email.
PROGRAM_PRICE_CENTS=29900

# Where you receive Zelle/Cash App payments — shown on your site.
ZELLE_INFO=yourname@yourdomain.com
CASHAPP_INFO=$YourCashtag

# Where the "someone paid, please confirm" email is sent — almost always
# your own inbox.
ADMIN_EMAIL=you@gmail.com

# A long random string that protects the one-click "confirm payment" link
# in your admin email so a stranger can't guess it and grant themselves
# access. Generate one with: node -e "console.log(require('crypto').randomBytes(24).toString('hex'))"
ADMIN_SECRET=replace_with_a_long_random_string

# ---- Gmail (SMTP) ----
# 1. Turn on 2-Step Verification on your Google account (myaccount.google.com/security)
# 2. Create an App Password at myaccount.google.com/apppasswords
#    (choose "Mail" as the app) — use that 16-character password below,
#    NOT your normal Gmail password.
GMAIL_USER=yourcoaching@gmail.com
GMAIL_APP_PASSWORD=your_16_char_app_password
FROM_NAME=Your Coaching Program
COACH_NAME=Your First Name

# ---- Program length ----
# How many weeks the weekly email sequence should run for
PROGRAM_LENGTH_WEEKS=8

# ---- Materials delivery (Wistia, token-gated) ----
# Your Wistia Channel ID — find it in Wistia: open your Channel's media
# page -> "Embed" -> the ID is the string after "wistia_async_" in the
# embed code shown there (e.g. wistia_async_65su5wva44 -> 65su5wva44).
#
# Access control does NOT come from Wistia — it comes from routes/materials.js,
# which only ever sends this embed to someone with a valid access_token
# (generated automatically when you confirm a payment). Wistia's Domain
# Restrictions (set separately in your Wistia dashboard, locked to your
# real domain) is a second layer on top, stopping the video from playing
# anywhere except this route even if the embed code were somehow copied.
WISTIA_CHANNEL_ID=your_channel_id

